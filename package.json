    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.43",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.61.1",
    "vitest": "^1.6.1"
