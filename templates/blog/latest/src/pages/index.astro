---
import { getEmDashCollection } from '@arrorera/emdash';

const { entries: posts } = await getEmDashCollection('posts');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Blog Template</title>
  </head>
  <body>
    <h1>Blog Template</h1>
    {posts.map((post: any) => (
      <article>
        <h2>{post.title}</h2>
        <p>{post.excerpt}</p>
      </article>
    ))}
  </body>
</html>
