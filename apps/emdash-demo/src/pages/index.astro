---
import { getEmDashCollection } from '@arrorera/emdash';

const { entries: posts } = await getEmDashCollection('posts');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>ArrorEra CMS Demo</title>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <main class="max-w-4xl mx-auto py-12 px-4">
      <h1 class="text-4xl font-bold text-gray-900 mb-8">ArrorEra CMS</h1>
      <p class="text-lg text-gray-600 mb-8">A modern, serverless-ready CMS built with Astro and TypeScript.</p>
      
      <div class="flex gap-4 mb-12">
        <a href="/emdash/admin" class="bg-black text-white px-6 py-2 rounded-md font-medium hover:bg-gray-800 transition">
          Open Admin Panel
        </a>
      </div>

      <h2 class="text-2xl font-semibold text-gray-800 mb-6">Latest Posts</h2>
      
      {posts.length === 0 ? (
        <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100 text-center">
          <p class="text-gray-500">No posts found. Run the seed script or create one in the admin panel.</p>
        </div>
      ) : (
        <div class="grid gap-6">
          {posts.map((post: any) => (
            <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
              <h3 class="text-xl font-bold text-gray-900 mb-2">{post.title}</h3>
              <p class="text-gray-600 mb-4">{post.excerpt}</p>
              <div class="text-sm text-gray-400">
                Published: {new Date(post.createdAt).toLocaleDateString()}
              </div>
            </article>
          ))}
        </div>
      )}
    </main>
  </body>
</html>
