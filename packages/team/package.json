{
  "name": "@arrowera/team",
  "version": "2.0.0",
  "description": "Enterprise Multi-tenant, RBAC & Organization Management for ArrowERA CMS",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.22.4",
    "uuid": "^9.0.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^9.0.7",
    "tsup": "^8.0.2",
    "vitest": "^1.3.1",
    "typescript": "^5.4.2"
  },
  "peerDependencies": {
    "@arrowera/db": "workspace:*",
    "@arrowera/auth": "workspace:*",
    "@arrowera/logging": "workspace:*"
  },
  "keywords": [
    "multi-tenant",
    "rbac",
    "organizations",
    "teams",
    "permissions",
    "enterprise",
    "arrowera"
  ],
  "license": "MIT"
}
