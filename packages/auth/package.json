{
  "name": "@arrowera/auth",
  "version": "2.0.0",
  "description": "Enterprise Authentication & Identity Platform for ArrowERA CMS",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.2",
    "jsonwebtoken": "^9.0.2",
    "otpauth": "^9.2.2",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "vitest": "^1.3.1"
  },
  "peerDependencies": {
    "@arrowera/db": "workspace:*",
    "@arrowera/logging": "workspace:*"
  },
  "keywords": [
    "authentication",
    "oauth",
    "passkey",
    "webauthn",
    "mfa",
    "totp",
    "jwt",
    "enterprise",
    "arrowera"
  ],
  "license": "MIT"
}
